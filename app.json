{
  "expo": {
    "name": "GuardLayer",
    "slug": "guard-layer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "guardlayer",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guardlayer.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "GuardLayer monitors your photo library to detect and flag potentially harmful images received through chat apps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.guardlayer.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "GuardLayer monitors photos to detect harmful images from chat apps.",
          "savePhotosPermission": false,
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "GuardLayer uses the microphone for voice monitoring to detect potential threats."
        }
      ],
      "expo-background-fetch",
      "expo-task-manager",
      "expo-haptics"
    ]
  }
}
